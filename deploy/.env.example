# Hermes Hub 生产部署变量示例。
# 复制本文件为 .env 后再部署；真实生产环境请务必替换所有 change-me 值。

# 镜像默认使用 latest，生产环境也可以固定到具体版本标签。
HERMES_HUB_BACKEND_IMAGE=ghcr.io/yiiilin/hermes-hub:latest
HERMES_DOCKER_IMAGE=ghcr.io/yiiilin/hermes-hub-hermes:latest

# Web/API 可以公开访问；其他服务在 compose 中固定绑定 127.0.0.1。
HERMES_HUB_HTTP_PORT=8080
HERMES_HUB_HTTP_HOST_BIND=0.0.0.0
HERMES_HUB_PUBLIC_PLATFORM_ENABLED=false

# backend 会通过宿主机 Docker daemon 创建用户 Hermes 容器。
# 该路径必须是宿主机绝对路径，并会以完全相同的路径 bind 到 backend 容器内。
HERMES_DATA_ROOT=/opt/hermes-hub/data/hub/users
HERMES_POSTGRES_DATA_DIR=/opt/hermes-hub/data/postgres
HERMES_RUSTFS_DATA_DIR=/opt/hermes-hub/data/rustfs
HERMES_CONTAINER_NETWORK=hermes-hub-net

# 数据库配置。Postgres 默认不对宿主机发布端口。
POSTGRES_DB=hermes_hub
POSTGRES_USER=hermes_hub
POSTGRES_PASSWORD=change-me-postgres

# 首次启动前请替换为高熵随机值，并长期保存；更换后历史密文可能无法解密。
# 可用命令生成：openssl rand -base64 32 | tr -d '='
HERMES_HUB_SECRET_MASTER_KEY=AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA
HERMES_HUB_COOKIE_NAME=hermes_hub_session

# 首次启动模型默认值，后续可由管理员在 UI 中调整。
HERMES_HUB_MODEL_PROVIDER_NAME=openai-compatible
HERMES_HUB_MODEL_PROVIDER_BASE_URL=https://api.openai.com/v1
HERMES_HUB_MODEL_PROVIDER_API_KEY=change-me-model-api-key
HERMES_HUB_DEFAULT_MODEL=gpt-4.1-mini
HERMES_HUB_ALLOWED_MODELS=gpt-4.1-mini
HERMES_HUB_MODEL_API_TYPE=responses
HERMES_HUB_MODEL_ALLOW_STREAMING=true
HERMES_HUB_MODEL_REQUEST_TIMEOUT_SECONDS=300
HERMES_HUB_MODEL_REASONING_EFFORT=medium

# RustFS/S3 兼容对象存储。API 和 Console 端口只绑定本机回环地址。
HERMES_OBJECT_STORAGE_ACCESS_KEY=rustfsadmin
HERMES_OBJECT_STORAGE_SECRET_KEY=change-me-rustfs-secret
HERMES_OBJECT_STORAGE_BUCKET=hermes-hub
HERMES_OBJECT_STORAGE_REGION=us-east-1
HERMES_OBJECT_STORAGE_FORCE_PATH_STYLE=true
HERMES_OBJECT_STORAGE_PREFIX=attachments
RUSTFS_CONSOLE_ENABLE=false
RUSTFS_API_HOST_PORT=9000
RUSTFS_CONSOLE_HOST_PORT=9001

# 托管技能 NFS 仅供宿主机 Docker daemon 使用，不应公开到外部网络。
HERMES_HUB_SKILLS_FS_HOST_PORT=12049
HERMES_HUB_MANAGED_SKILLS_MOUNT_ENABLED=true
HERMES_HUB_MANAGED_SKILLS_VOLUME_NAME=hermes-hub-managed-skills
HERMES_HUB_MANAGED_SKILLS_NFS_ADDR=127.0.0.1:12049
HERMES_HUB_MANAGED_SKILLS_NFS_EXPORT=/skills
HERMES_HUB_MANAGED_SKILLS_CONTAINER_PATH=/nfs

# 用户 Hermes 容器资源限制。
HERMES_CONTAINER_INTERNAL_PORT=8000
HERMES_CONTAINER_MEMORY_LIMIT=1g
HERMES_CONTAINER_CPU_LIMIT=1.0
HERMES_DOCKER_BINARY=docker
# 可选 Docker CLI 兼容参数；通常留空，由 backend 在需要时自动降级 API。
DOCKER_HOST=
DOCKER_API_VERSION=
HERMES_HUB_MAX_PROXY_BODY_BYTES=10485760
HERMES_OBJECT_STORAGE_MAX_UPLOAD_BYTES=26214400

# 浏览器语音输入默认关闭。启用 ASR 时取消下一行注释，并把部署级开关改成 true。
# COMPOSE_PROFILES=asr
HERMES_HUB_SPEECH_INPUT_ENABLED=false
HERMES_HUB_ASR_ENDPOINT=http://asr:9991
HERMES_HUB_ASR_TRANSCRIBE_PATH=/v1/audio/transcriptions
HERMES_HUB_ASR_MODEL=sensevoice
HERMES_HUB_ASR_TIMEOUT_SECONDS=90
HERMES_HUB_ASR_MAX_AUDIO_SECONDS=60
HERMES_HUB_ASR_MAX_UPLOAD_BYTES=26214400
HERMES_HUB_ASR_IMAGE=ghcr.io/yiiilin/hermes-hub-asr:0.0.17
# 默认 ASR 镜像使用 sherpa-onnx + SenseVoice int8；下面这些变量只传给 ASR 容器。
HERMES_HUB_ASR_CPU_NUM=4
HERMES_HUB_ASR_PORT=9991
HERMES_HUB_ASR_USE_ITN=true
HERMES_HUB_ASR_MODEL_DIR=/opt/hermes-hub/data/asr/models
HERMES_HUB_ASR_MODEL_URL=https://github.com/k2-fsa/sherpa-onnx/releases/download/asr-models/sherpa-onnx-sense-voice-zh-en-ja-ko-yue-int8-2024-07-17.tar.bz2
HERMES_HUB_ASR_MODEL_ARCHIVE=sherpa-onnx-sense-voice-zh-en-ja-ko-yue-int8-2024-07-17.tar.bz2
HERMES_HUB_ASR_MODEL_DIR_NAME=sherpa-onnx-sense-voice-zh-en-ja-ko-yue-int8-2024-07-17
HERMES_HUB_ASR_MODEL_FILE=model.int8.onnx
HERMES_HUB_ASR_TOKENS_FILE=tokens.txt
HERMES_HUB_ASR_MODEL_SHA256=7d1efa2138a65b0b488df37f8b89e3d91a60676e416f515b952358d83dfd347e
HERMES_HUB_ASR_DOWNLOAD_TIMEOUT_SECONDS=60
HERMES_HUB_ASR_DOWNLOAD_RETRIES=3
HERMES_HUB_ASR_FFMPEG_TIMEOUT_SECONDS=180

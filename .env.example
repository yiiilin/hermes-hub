# 当前运行时代码会读取监听地址和 Cookie 名称。
HERMES_HUB_BIND_ADDR=0.0.0.0:8080
HERMES_HUB_COOKIE_NAME=hermes_hub_session

# 设置 DATABASE_URL 后启用 PostgreSQL/SQLx 持久化；不设置时使用内存模式。
DATABASE_URL=postgres://hermes_hub:hermes_hub@localhost:5432/hermes_hub

# PostgreSQL 模式必填。示例值不能用于生产。
HERMES_HUB_SECRET_MASTER_KEY=AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA

# 托管 Hermes 容器配置。backend 需要能访问 Docker daemon。
HERMES_DATA_ROOT=/data/hermes-hub/users
HERMES_DOCKER_IMAGE=nousresearch/hermes-agent:latest
HERMES_CONTAINER_NETWORK=hermes-hub-net
HERMES_CONTAINER_INTERNAL_PORT=8000
HERMES_HUB_LLM_BASE_URL=http://hermes-hub:8080/internal/llm/v1
HERMES_CONTAINER_MEMORY_LIMIT=1g
HERMES_CONTAINER_CPU_LIMIT=1.0
HERMES_DOCKER_BINARY=docker

# 代理保护：限制浏览器到 Hermes、Hermes 到模型供应商的单次请求体大小和超时。
HERMES_HUB_PROXY_TIMEOUT_SECONDS=60
HERMES_HUB_MAX_PROXY_BODY_BYTES=10485760
